{
  "name": "taskdock",
  "version": "0.0.3",
  "description": "TaskDock - Desktop productivity app with PR Review and more",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"tauri dev\"",
    "dev:renderer": "vite",
    "dev:backend": "tsx src-backend/bridge.ts",
    "build": "npm run build:renderer && npm run build:sidecar && tauri build",
    "build:renderer": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:bundle": "esbuild src-backend/bridge.ts --bundle --platform=node --target=node20 --outfile=dist/sidecar/bridge.cjs --format=cjs --external:@lydell/node-pty --external:@lydell/node-pty-win32-x64",
    "build:sidecar": "npm run build:bundle && pkg dist/sidecar/bridge.cjs --config pkg.config.json --targets node20-win-x64 --output src-tauri/binaries/backend && node -e \"require('fs').renameSync('src-tauri/binaries/backend.exe', 'src-tauri/binaries/backend-x86_64-pc-windows-msvc.exe')\"",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri"
  },
  "pkg": {
    "scripts": [
      "dist/backend/**/*.js"
    ],
    "assets": [],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "src-tauri/binaries"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.12",
    "@anthropic-ai/sdk": "^0.71.2",
    "@github/copilot-sdk": "^0.1.13",
    "@lydell/node-pty": "^1.2.0-beta.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "diff": "^5.2.0",
    "highlight.js": "^11.10.0",
    "lru-cache": "^11.2.5",
    "lucide-static": "^0.563.0",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "pino": "^10.1.0",
    "rotating-file-stream": "^3.2.7",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@types/diff": "^5.2.1",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@yao-pkg/pkg": "^6.12.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.27.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "lodash-es": "^4.17.23"
  }
}
