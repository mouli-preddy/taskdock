{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskdock.dev/schemas/plugin-manifest.json",
  "title": "TaskDock Plugin Manifest",
  "description": "Schema for validating TaskDock plugin manifest.json files",
  "type": "object",
  "required": ["id", "name", "version", "description", "triggers"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Unique plugin identifier (lowercase alphanumeric with hyphens)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Semantic version (e.g. 1.0.0)"
    },
    "description": {
      "type": "string",
      "description": "Brief description of what the plugin does"
    },
    "config": {
      "type": "object",
      "description": "Configuration fields shown in plugin settings UI",
      "additionalProperties": {
        "$ref": "#/definitions/configField"
      }
    },
    "triggers": {
      "type": "array",
      "description": "Workflow triggers (manual, polling, or scheduled)",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/trigger"
      }
    },
    "hooks": {
      "type": "object",
      "description": "Buttons and panels injected into built-in TaskDock tabs",
      "additionalProperties": false,
      "properties": {
        "pr-review": { "$ref": "#/definitions/hookSet" },
        "pr-home": { "$ref": "#/definitions/hookSet" },
        "workitems": { "$ref": "#/definitions/hookSet" },
        "terminals": { "$ref": "#/definitions/hookSet" }
      }
    }
  },
  "definitions": {
    "configField": {
      "type": "object",
      "required": ["type", "label"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean"],
          "description": "Data type of the config field"
        },
        "label": {
          "type": "string",
          "description": "Label shown in the settings UI"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this field must be set before the plugin can run"
        },
        "default": {
          "description": "Default value if not set by the user",
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        },
        "secret": {
          "type": "boolean",
          "description": "If true, the value is masked in the UI (for API tokens, passwords)"
        }
      }
    },
    "trigger": {
      "oneOf": [
        { "$ref": "#/definitions/manualTrigger" },
        { "$ref": "#/definitions/pollingTrigger" },
        { "$ref": "#/definitions/scheduledTrigger" }
      ]
    },
    "manualTrigger": {
      "type": "object",
      "required": ["type", "id", "workflow", "label"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "manual" },
        "id": { "type": "string", "description": "Unique trigger identifier within this plugin" },
        "workflow": { "type": "string", "description": "Path to the workflow script relative to plugin root" },
        "label": { "type": "string", "description": "Button label shown in the UI" },
        "timeout": { "type": "number", "description": "Max execution time in seconds (default: 60)" }
      }
    },
    "pollingTrigger": {
      "type": "object",
      "required": ["type", "id", "workflow", "interval"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "polling" },
        "id": { "type": "string", "description": "Unique trigger identifier within this plugin" },
        "workflow": { "type": "string", "description": "Path to the workflow script relative to plugin root" },
        "interval": {
          "type": "string",
          "description": "Polling interval (e.g. '30s', '5m', '{{config.pollInterval}}s')"
        },
        "timeout": { "type": "number", "description": "Max execution time in seconds (default: 60)" }
      }
    },
    "scheduledTrigger": {
      "type": "object",
      "required": ["type", "id", "workflow", "cron"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "scheduled" },
        "id": { "type": "string", "description": "Unique trigger identifier within this plugin" },
        "workflow": { "type": "string", "description": "Path to the workflow script relative to plugin root" },
        "cron": {
          "type": "string",
          "description": "Cron expression (minute hour day month weekday), e.g. '0 9 * * 1-5'"
        },
        "timeout": { "type": "number", "description": "Max execution time in seconds (default: 60)" }
      }
    },
    "hookSet": {
      "type": "object",
      "description": "Hook locations within a tab",
      "additionalProperties": false,
      "properties": {
        "toolbar": {
          "type": "array",
          "items": { "$ref": "#/definitions/hookButton" }
        },
        "row-actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/hookButton" }
        },
        "file-context-menu": {
          "type": "array",
          "items": { "$ref": "#/definitions/hookButton" }
        },
        "comments-toolbar": {
          "type": "array",
          "items": { "$ref": "#/definitions/hookButton" }
        },
        "bottom-panel": {
          "type": "array",
          "items": { "$ref": "#/definitions/hookButton" }
        }
      }
    },
    "hookButton": {
      "type": "object",
      "required": ["label", "icon", "trigger"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "description": "Button label" },
        "icon": { "type": "string", "description": "Lucide icon name (e.g. 'play', 'shield', 'sparkles')" },
        "trigger": { "type": "string", "description": "Trigger ID to invoke when clicked" },
        "position": {
          "type": "string",
          "enum": ["left", "right"],
          "description": "Button position in toolbar (default: left)"
        }
      }
    }
  }
}
