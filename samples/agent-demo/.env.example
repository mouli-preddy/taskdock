# Azure DevOps Configuration
ADO_ORG_URL=https://dev.azure.com/your-organization
ADO_PROJECT=your-project-name

# Optional: Personal Access Token (if not using az login)
# AZURE_DEVOPS_PAT=your-pat-token

# Working directory for file operations (defaults to current directory)
# WORKING_DIR=/path/to/your/project

# Output directory for design documents (defaults to ./docs/designs)
# DOCS_OUTPUT_DIR=./docs/designs
