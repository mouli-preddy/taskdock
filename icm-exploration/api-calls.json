    "timestamp": "2026-02-08T23:22:31.870Z",
    "method": "GET",
    "url": "https://portal.microsofticm.com/sso2/IdentityProviderSelection.html?ReturnUrl=https%3A%2F%2Fportal.microsofticm.com%2Fimp%2Fv3%2Fincidents%2Fsearch%2Fadvanced&activeIdentityProviders=IcMdSTS,EntraID-OIDC,IcMdSTSMooncake",
    "requestHeaders": {
      "upgrade-insecure-requests": "1",
      "user-agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36 Edg/143.0.0.0",
      "sec-ch-ua": "\"Microsoft Edge\";v=\"143\", \"Chromium\";v=\"143\", \"Not A(Brand\";v=\"24\"",
      "sec-ch-ua-mobile": "?0",
      "sec-ch-ua-platform": "\"Windows\""
